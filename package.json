{
  "name": "spark-charts",
  "version": "0.1.4",
  "description": "A lightweight canvas charting library for time-series: crosshair, area fills, threshold lines, pan/zoom, smart date axis, add/remove series.",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "dev": "node build.mjs --serve",
    "build": "node build.mjs",
    "build:lib": "node build.mjs --lib && tsc -p tsconfig.json --emitDeclarationOnly --outDir dist",
    "typecheck": "tsc -p tsconfig.eslint.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check": "npm run typecheck && npm run lint",
    "prepack": "npm run build:lib",
    "prepublishOnly": "npm run check"
  },
  "keywords": [
    "chart",
    "charts",
    "canvas",
    "timeseries",
    "crosshair",
    "finance",
    "typescript"
  ],
  "author": "Mukul Sabharwal <mjsabby@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mjsabby/spark-charts.git"
  },
  "homepage": "https://github.com/mjsabby/spark-charts#readme",
  "bugs": {
    "url": "https://github.com/mjsabby/spark-charts/issues"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "esbuild": "0.24.0",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.61.0"
  },
  "allowScripts": {
    "esbuild@0.24.0": true
  }
}
